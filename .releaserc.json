{
  "branches": [
    "main",
    { "name": "next", "channel": "next", "prerelease": "next" },
    {
      "name": "feat/**",
      "channel": "${name.replace(/^feat\\//, '').replace(/[^a-zA-Z0-9-]/g, '-')}",
      "prerelease": "${name.replace(/^feat\\//, '').replace(/[^a-zA-Z0-9-]/g, '-')}"
    }
  ],
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "releaseRules": [
          { "type": "perf", "release": false }
        ]
      }
    ],
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      { "changelogFile": "CHANGELOG.md" }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "node scripts/sync-common-version.js ${nextRelease.version}"
      }
    ],
    "@semantic-release/npm",
    [
      "@semantic-release/exec",
      {
        "publishCmd": "npm publish --workspace src/common --access public --tag ${nextRelease.channel || 'latest'}"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "CHANGELOG.md",
          "package.json",
          "package-lock.json",
          "src/common/package.json"
        ],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    "@semantic-release/github"
  ]
}
