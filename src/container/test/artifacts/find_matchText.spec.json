{
  "id": "matchTextRegex",
  "tests": [
    {
      "steps": [
        {
          "goTo": {
            "url": "https://example.com/",
            "timeout": 60000
          }
        },
        {
          "find": {
            "elementText": "Example Domain",
            "timeout": 30000
          }
        },
        {
          "find": {
            "elementText": "/^Example Domain$/",
            "timeout": 30000
          }
        },
        {
          "find": {
            "elementText": "/^E.*?n$/",
            "timeout": 30000
          }
        }
      ]
    }
  ]
}
