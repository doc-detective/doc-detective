{
  "specId": "matchTextRegex",
  "tests": [
    {
      "steps": [
        {
          "loadVariables": "env"
        },
        {
          "goTo": "$URL"
        },
        {
          "find": {
            "selector": "#text-elements > h2",
            "elementText": "Text Elements"
          }
        },
        {
          "find": {
            "selector": "#text-elements > h2",
            "elementText": "/^Text Elements$/"
          }
        },
        {
          "find": {
            "selector": "#text-elements > h2",
            "elementText": "/^T.*?s/"
          }
        }
      ]
    }
  ]
}
