{
  "id": "matchTextRegex",
  "tests": [
    {
      "steps": [
        {
          "action": "goTo",
          "url": "https://docs.doc-detective.com/docs/actions/type",
          "wait": {
            "timeout": 30000
          }
        },
        {
          "action": "find",
          "elementText": "Special keys",
          "matchText": "Special keys",
          "timeout": 30000
        },
        {
          "action": "find",
          "elementText": "Special keys",
          "matchText": "/^Special keys$/",
          "timeout": 30000
        },
        {
          "action": "find",
          "elementText": "Special keys",
          "matchText": "/^S.*?s/",
          "timeout": 30000
        }
      ]
    }
  ]
}
