{
  "id": "matchTextRegex",
  "tests": [
    {
      "steps": [
        {
          "goTo": {
            "url": "data:text/html,<!doctype html><html><body><h1>Find fixture</h1><h2>Special keys</h2></body></html>",
            "timeout": 30000
          }
        },
        {
          "find": {
            "elementText": "Special keys",
            "timeout": 30000
          }
        },
        {
          "find": {
            "elementText": "/^Special keys$/",
            "timeout": 30000
          }
        },
        {
          "find": {
            "elementText": "/^S.*?s/",
            "timeout": 30000
          }
        }
      ]
    }
  ]
}
