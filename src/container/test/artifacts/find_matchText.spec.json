{
  "id": "matchTextRegex",
  "tests": [
    {
      "steps": [
        {
          "action": "goTo",
          "url": "https://docs.doc-detective.com/docs/actions/type"
        },
        {
          "action": "find",
          "selector": "h2#special-keys",
          "matchText": "Special keys",
          "timeout": 30000
        },
        {
          "action": "find",
          "selector": "h2#special-keys",
          "matchText": "/^Special keys$/",
          "timeout": 30000
        },
        {
          "action": "find",
          "selector": "h2#special-keys",
          "matchText": "/^S.*?s/",
          "timeout": 30000
        }
      ]
    }
  ]
}
