{
  "tests": [
    {
      "description": "Exercises the three type shapes (array, string, object) in a single driver session to avoid chromedriver-restart flake inside the container.",
      "steps": [
        {
          "loadVariables": "env"
        },
        {
          "goTo": "$URL"
        },
        {
          "find": "#text-input"
        },
        {
          "type": [
            "kittens",
            "$ENTER$"
          ]
        },
        {
          "goTo": "$URL"
        },
        {
          "find": "#text-input"
        },
        {
          "type": "kittens"
        },
        {
          "goTo": "$URL"
        },
        {
          "find": "#text-input"
        },
        {
          "type": {
            "keys": [
              "kittens",
              "$ENTER$"
            ],
            "inputDelay": 100
          }
        }
      ]
    }
  ]
}
