{
  "id": "Do all the things! - Spec",
  "tests": [
    {
      "id": "Do all the things! - Test",
      "description": "This test includes nearly every property across all actions.",
      "setup": "setup.spec.json",
      "cleanup": "cleanup.spec.json",
      "steps": [
        {
          "loadVariables": "env"
        },
        {
          "checkLink": "$URL"
        },
        {
          "goTo": "$URL"
        },
        {
          "startRecording": {}
        },
        {
          "find": {
            "selector": "#text-input",
            "timeout": 10000,
            "moveTo": true,
            "click": true,
            "type": {
              "keys": [
                "shorthair cat",
                "$ENTER$"
              ]
            }
          }
        },
        {
          "stopRecording": {}
        }
      ]
    }
  ]
}
