  "examples": [
    "kittens",
    [
      "$ENTER$"
    ],
    [
      "kittens",
      "$ENTER$"
    ],
    {
      "keys": "kittens"
    },
    {
      "keys": [
        "$ENTER$"
      ]
    },
    {
      "keys": [
        "kittens",
        "$ENTER$"
      ],
      "inputDelay": 500
    },
    {
      "keys": [
        "2+2",
        "$ENTER$"
      ],
      "surface": "node",
      "waitUntil": {
        "stdio": "/^4$/"
      },
      "timeout": 5000
    },
    {
      "keys": [
        "$CTRL$",
        "c"
      ],
      "surface": {
        "process": "node"
      }
    }
  ]
}