          {
            "url": "/checkout",
            "origin": "https://my-app.com",
            "newTab": "cart"
          },
          {
            "url": "/admin",
            "origin": "https://my-app.com",
            "newWindow": {
              "name": "admin",
              "tab": "overview"
            }
          },
          {
            "url": "/orders",
            "surface": {
              "browser": "chrome",
              "window": "admin",
              "tab": "overview"
            }
          }
        ]
      }
