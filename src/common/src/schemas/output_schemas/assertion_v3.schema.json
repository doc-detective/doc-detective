{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "assertion",
  "description": "An articulated assertion record produced by the runner for a step result. Each record names a single verification check, whether it passed, and the values it compared. The step's result is the roll-up of its assertion results (FAIL > WARNING > all-SKIPPED > PASS). System-populated; appears in test results, not in authored specs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "statement",
    "source",
    "result"
  ],
  "properties": {
    "statement": {
      "description": "Human-readable articulation of the check, e.g. `exitCode in [0]`.",
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "source": {
      "description": "Who defined the assertion: `implicit` (runner-defined) or `custom` (user-defined).",
      "type": "string",
      "enum": [
        "implicit",
        "custom"
      ]
    },
    "result": {
      "description": "Outcome of evaluating the assertion.",
      "type": "string",
      "enum": [
        "PASS",
        "FAIL",
        "WARNING",
        "SKIPPED"
      ]
    },
    "expected": {
      "description": "The value (or values) the assertion expected. Optional.",
      "type": [
        "array",
        "boolean",
        "integer",
        "null",
        "number",
        "object",
        "string"
      ]
    },
    "actual": {
      "description": "The value actually observed. Optional.",
      "type": [
        "array",
        "boolean",
        "integer",
        "null",
        "number",
        "object",
        "string"
      ]
    },
    "description": {
      "description": "Human-readable explanation of the outcome. Optional.",
      "type": "string"
    }
  },
  "examples": [
    {
      "statement": "exitCode in [0]",
      "source": "implicit",
      "result": "PASS",
      "expected": [
        0
      ],
      "actual": 0,
      "description": "Returned exit code 0."
    },
    {
      "statement": "exitCode in [0]",
      "source": "implicit",
      "result": "FAIL",
      "expected": [
        0
      ],
      "actual": 1,
      "description": "Returned exit code 1. Expected one of [0]."
    },
    {
      "statement": "saved-file variation <= 0.1",
      "source": "implicit",
      "result": "WARNING"
    },
    {
      "statement": "$$outputs.exitCode == 0",
      "source": "custom",
      "result": "SKIPPED"
    }
  ]
}