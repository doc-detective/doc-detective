{
  "specId": "screenshot-annotations",
  "description": "End-to-end coverage for screenshot annotations. Every annotation type, every target shape (string, find object, position), per-annotation style overrides, the annotationDefaults cascade, annotations combined with crop, and `all` for multi-element redaction. Annotations are composited into the image with sharp rather than injected into the page, so these run headless on every platform and need no display. Specs can only assert PASS/SKIPPED — the FAIL paths (missing target, `all` with a string target) are pinned in test/annotations-screenshot.test.js.",
  "tests": [
    {
      "testId": "annotations-types",
      "description": "Each of the six annotation types against a string target.",
      "steps": [
        {
          "goTo": "http://localhost:8092/enhanced-elements.html"
        },
        {
          "stepId": "annotation-outline",
          "screenshot": {
            "path": "annotation-outline.png",
            "directory": "static/images",
            "overwrite": "true",
            "annotations": [
              {
                "outline": "#submit-button"
              }
            ]
          }
        },
        {
          "stepId": "annotation-arrow",
          "screenshot": {
            "path": "annotation-arrow.png",
            "directory": "static/images",
            "overwrite": "true",
            "annotations": [
              {
                "arrow": "#submit-button"
              }
            ]
          }
        },
        {
          "stepId": "annotation-badge",
          "screenshot": {
            "path": "annotation-badge.png",
            "directory": "static/images",
            "overwrite": "true",
            "annotations": [
              {
                "badge": "#submit-button",
                "label": "1"
              }
            ]
          }
        },
        {
          "stepId": "annotation-callout",
          "screenshot": {
            "path": "annotation-callout.png",
            "directory": "static/images",
            "overwrite": "true",
            "annotations": [
              {
                "callout": "#submit-button",
                "label": "Submits the form",
                "position": "right"
              }
            ]
          }
        },
        {
          "stepId": "annotation-blur",
          "screenshot": {
            "path": "annotation-blur.png",
            "directory": "static/images",
            "overwrite": "true",
            "annotations": [
              {
                "blur": "#username-input"
              }
            ]
          }
        },
        {
          "stepId": "annotation-text",
          "screenshot": {
            "path": "annotation-text.png",
            "directory": "static/images",
            "overwrite": "true",
            "annotations": [
              {
                "text": {
                  "position": "top-right"
                },
                "label": "Demo environment"
              }
            ]
          }
        }
      ]
    },
    {
