{
  "specId": "recording-checkpoints",
  "description": "Recording checkpoints (ADR 01072): while a checkpoint-enabled recording is active, every step captures a compare-only screenshot against a persistent baseline beside the recording. Test 1 is the first run (baselines seed at stopRecord, maxCheckpointVariation 0); test 2 replays the identical span against the seeded baselines (comparison path, variation within tolerance on the static test page). Headed-only like all recordings; compareOnly/no-write mechanics are unit-tested in test/recording-checkpoints.test.js.",
  "tests": [
    {
      "testId": "checkpoints-seed",
      "description": "First run: checkpoints stage captures and stopRecord seeds the baselines.",
      "runOn": [
        {
          "platforms": [
            "windows",
            "mac"
          ],
          "browsers": {
            "name": "chrome",
            "headless": false
          }
        }
      ],
      "steps": [
        {
          "goTo": "http://localhost:8092"
        },
        {
          "record": {
            "path": "checkpoints-demo.mp4",
            "engine": {
              "name": "ffmpeg",
              "target": "display"
            },
            "overwrite": "true",
            "checkpoints": true
          }
        },
        {
          "find": {
            "selector": "body",
            "timeout": 5000
          }
        },
        {
          "stopRecord": true,
          "variables": {
            "CKPT_SEED_MAX_VARIATION": "$$maxCheckpointVariation",
            "CKPT_SEEDED": "$$seededBaselines"
          }
        },
        {
          "description": "Assert the first run seeded baselines (record bookend + find step) and had nothing to differ from.",
          "runShell": "node -e \"process.exit(Number('$CKPT_SEED_MAX_VARIATION') === 0 && Number('$CKPT_SEEDED') >= 2 ? 0 : 1)\""
        }
      ]
    },
    {
      "testId": "checkpoints-compare",
      "description": "Second run of the identical span: checkpoints compare against the baselines test 1 seeded.",
      "runOn": [
        {
          "platforms": [
            "windows",
            "mac"
          ],
          "browsers": {
            "name": "chrome",
            "headless": false
          }
        }
      ],
      "steps": [
        {
          "goTo": "http://localhost:8092"
        },
        {
          "record": {
            "path": "checkpoints-demo.mp4",
            "engine": {
              "name": "ffmpeg",
              "target": "display"
            },
            "overwrite": "true",
            "checkpoints": true
          }
        },
        {
          "find": {
            "selector": "body",
            "timeout": 5000
          }
        },
        {
          "stopRecord": true,
          "variables": {
            "CKPT_COMPARE_MAX_VARIATION": "$$maxCheckpointVariation",
            "CKPT_COMPARE_SEEDED": "$$seededBaselines"
          }
        },
        {
          "description": "Assert this run COMPARED (seeded nothing) and the static page stayed within tolerance.",
          "runShell": "node -e \"const v = Number('$CKPT_COMPARE_MAX_VARIATION'); process.exit(Number('$CKPT_COMPARE_SEEDED') === 0 && Number.isFinite(v) && v <= 0.05 ? 0 : 1)\""
        }
      ]
    }
  ]
}
