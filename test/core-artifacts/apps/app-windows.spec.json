{
  "specId": "app-window-selectors-windows",
  "description": "App window selectors on Windows (ADR 01036, docs/design/native-app-surfaces.md §'The surface reference — app branch'): the NovaWindows driver is one-root-window-at-a-time, so a window selector switches the session root (switch-then-act) and stays sticky. The target app is a purpose-built two-window WinForms app (two-windows.ps1, launched through powershell.exe) — the app-surface counterpart of the test-server pages — because every candidate System32 dialog app carries a confounder: odbcad32/osk/eudcedit have highestAvailable/uiAccess manifests that demand elevation for admin users, dxdiag gates its buttons behind a hardware scan and shows crash-recovery modals, and menu popups are separate top-level HWNDs outside the rooted window subtree. The app script is passed via -EncodedCommand (base64 of two-windows.ps1, UTF-16LE) because NovaWindows v1.4.1 ignores the appWorkingDir capability, so relative -File paths don't resolve; a unit test in test/app-windows.test.js re-encodes the .ps1 and pins the spec's blob against drift. Gated to Windows hosts; SKIPPED elsewhere.",
  "tests": [
    {
      "testId": "win-window-select-and-close",
      "description": "Open the second window via the app's button, find inside it via a title window selector (and again with no selector — sticky proof: the session stays rooted there), screenshot that window, close JUST it with window: -1 (newest), prove the main window survived, then close the whole surface.",
      "runOn": [
        {
          "platforms": [
            "windows"
          ],
          "requires": {
            "files": [
              "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe"
            ]
          }
        }
      ],
      "steps": [
        {
          "startSurface": {
            "app": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
            "name": "twowin",
            "args": [
              "-NoProfile",
              "-ExecutionPolicy",
              "Bypass",
              "-WindowStyle",
              "Hidden",
              "-EncodedCommand",
              ""
            ],
            "timeout": 120000,
            "waitUntil": {
              "find": {
                "elementText": "Open Dialog"
              }
            }
          }
        },
        {
          "click": {
            "elementText": "Open Dialog",
            "surface": {
              "app": "twowin",
              "window": {
                "title": "DD Main Window"
              }
            },
            "timeout": 30000
          }
        },
        {
          "find": {
            "elementText": "Dialog content",
            "surface": {
              "app": "twowin",
              "window": {
                "title": "/Second Window/"
              }
            },
            "timeout": 30000
          }
        },
        {
          "find": {
            "elementText": "Dialog content",
            "surface": {
              "app": "twowin"
            },
            "timeout": 15000
          }
        },
        {
          "screenshot": {
            "path": "twowin-second-window.png",
            "overwrite": "true",
            "surface": {
              "app": "twowin",
              "window": {
                "title": "DD Second Window"
              }
            }
          }
        },
        {
          "closeSurface": {
            "app": "twowin",
            "window": -1
          }
        },
        {
          "find": {
            "elementText": "Open Dialog",
            "surface": {
              "app": "twowin"
            },
            "timeout": 15000
          }
        },
        {
          "closeSurface": {
            "app": "twowin"
          }
        }
      ]
    },
    {
      "testId": "win-window-selected-recording",
      "description": "Record with a window selector targeting the main window by title: the crop binds to THAT window's rect. The second window opens during the recording (interactions give the capture real frames); the recording stays cropped to the main window.",
      "runOn": [
        {
          "platforms": [
            "windows"
          ],
          "requires": {
            "files": [
              "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe"
            ]
          }
        }
      ],
      "steps": [
        {
          "startSurface": {
            "app": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
            "name": "twowin",
            "args": [
              "-NoProfile",
              "-ExecutionPolicy",
              "Bypass",
              "-WindowStyle",
              "Hidden",
              "-EncodedCommand",
              ""
            ],
            "timeout": 120000,
            "waitUntil": {
              "find": {
                "elementText": "Open Dialog"
              }
            }
          }
        },
        {
          "record": {
            "path": "twowin-main-window.mp4",
            "overwrite": "true",
            "surface": {
              "app": "twowin",
              "window": {
                "title": "DD Main Window"
              }
            }
          }
        },
        {
          "click": {
            "elementText": "Open Dialog",
            "surface": {
              "app": "twowin",
              "window": {
                "title": "DD Main Window"
              }
            },
            "timeout": 30000
          }
        },
        {
          "find": {
            "elementText": "Dialog content",
            "surface": {
              "app": "twowin",
              "window": {
                "title": "DD Second Window"
              }
            },
            "timeout": 30000
          }
        },
        {
          "stopRecord": true
        },
        {
          "closeSurface": {
            "app": "twowin"
          }
        }
      ]
    }
  ]
}
