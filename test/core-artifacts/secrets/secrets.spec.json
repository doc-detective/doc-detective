{
  "tests": [
    {
      "testId": "secret_in_request_header",
      "description": "A secret rides an Authorization header (an allowed emit sink) and reaches the server.",
      "steps": [
        {
          "loadVariables": "../env"
        },
        {
          "httpRequest": {
            "url": "http://localhost:8092/api/users",
            "method": "post",
            "request": {
              "headers": {
                "Authorization": "Bearer $secret.SECRET"
              },
              "body": {
                "name": "header-auth"
              }
            },
            "statusCodes": [
              200,
              201
            ]
          }
        }
      ]
    },
    {
      "testId": "secret_in_request_body",
      "description": "A secret rides a request body field. The reference is a substring of a larger value.",
      "steps": [
        {
          "loadVariables": "../env"
        },
        {
          "httpRequest": {
            "url": "http://localhost:8092/api/users",
            "method": "post",
            "request": {
              "body": {
                "token": "prefix-$secret.SECRET-suffix"
              }
            },
            "statusCodes": [
              200,
              201
            ]
          }
        }
      ]
    },
    {
      "testId": "secret_in_url_query",
      "description": "A secret rides a URL query parameter.",
      "steps": [
        {
          "loadVariables": "../env"
        },
        {
          "httpRequest": {
            "url": "http://localhost:8092/api/users",
            "method": "post",
            "request": {
              "parameters": {
                "token": "$secret.SECRET"
              },
              "body": {
                "name": "query-auth"
              }
            },
            "statusCodes": [
              200,
              201
            ]
          }
        }
      ]
    },
    {
      "testId": "secret_in_shell_command",
      "description": "A secret rides a shell command argument. `runShell` joins command+args into one shell line, so the inline script deliberately contains no quotes, parens, or other shell metacharacters — and it prints nothing, keeping the credential out of stdio.",
      "steps": [
        {
          "loadVariables": "../env"
        },
        {
          "runShell": {
            "command": "node",
            "args": [
              "--eval",
              "process.exitCode=0",
              "$secret.SECRET"
            ],
            "exitCodes": [
              0
            ]
          }
        }
      ]
    },
    {
      "testId": "secret_typed_into_a_page",
      "description": "A secret is typed into an input (the canonical browser sink). Nothing asserts on the value.",
      "steps": [
        {
          "loadVariables": "../env"
        },
        {
          "goTo": "http://localhost:8092"
        },
        {
          "find": "#text-input"
        },
        {
          "type": "$secret.SECRET"
        }
      ]
    },
    {
      "testId": "multiple_secrets_in_one_step",
      "description": "Two references in a single value both resolve.",
      "steps": [
        {
          "loadVariables": "../env"
        },
        {
          "httpRequest": {
            "url": "http://localhost:8092/api/users",
            "method": "post",
            "request": {
              "body": {
                "pair": "$secret.SECRET:$secret.SECRET"
              }
            },
            "statusCodes": [
              200,
              201
            ]
          }
        }
      ]
    },
    {
      "testId": "plain_variables_still_resolve_alongside_secrets",
      "description": "A `$VAR` reference keeps its long-standing behavior in the same step as a `$secret.` one.",
      "steps": [
        {
          "loadVariables": "../env"
        },
        {
          "httpRequest": {
            "url": "http://localhost:8092/api/users",
            "method": "post",
            "request": {
              "headers": {
                "Authorization": "Bearer $secret.SECRET"
              },
              "body": {
                "name": "$USER"
              }
            },
            "response": {
              "body": {
                "name": "John Doe"
              }
            },
            "statusCodes": [
              200,
              201
            ]
          }
        }
      ]
    }
  ]
}
