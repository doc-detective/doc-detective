{
  "id": "matchTextRegex",
  "tests": [
    {
      "steps": [
        {
          "action": "goTo",
          "url": "http://localhost:8092"
        },
        {
          "action": "find",
          "selector": "#text-elements > h2",
          "matchText": "Text Elements"
        },
        {
          "action": "find",
          "selector": "#text-elements > h2",
          "matchText": "/^Text Elements$/"
        },
        {
          "action": "find",
          "selector": "#text-elements > h2",
          "matchText": "/^T.*?s/"
        }
      ]
    }
  ]
}
